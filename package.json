	"scripts": {
		"build": "node tools/build/cli.ts",
		"deploy": "node --run lint && node --run test && node tools/deploy.ts",
		"deploy-all": "node --run lint && node --run test && node tools/deploy-all.ts",
		"dev": "node tools/watch/cli.ts",
		"preview": "node tools/preview.ts",
		"lint": "concurrently --raw \"node --run lint-js\" \"node --run lint-ts\"",
		"lint-js": "node --run pre-test && eslint",
		"lint-ts": "node --run pre-test && tsc --build",
		"pre-test": "node tools/pre-test.ts",
		"format": "oxfmt",
		"test": "node --run pre-test && vitest --run",
		"prepare": "husky",
		"postinstall": "playwright install"
	},
	"lint-staged": {
		"*": "oxfmt --no-error-on-unmatched-pattern"
